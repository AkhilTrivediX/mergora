{
  "name": "mergora-registry",
  "version": "1.0.0",
  "private": false,
  "description": "Private scaffold for the Mergora registry SDK",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AkhilTrivediX/mergora.git",
    "directory": "packages/registry"
  },
  "homepage": "https://mergora.vercel.app/",
  "bugs": "https://github.com/AkhilTrivediX/mergora/issues",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "postcss": "catalog:",
    "typescript": "catalog:"
  }
}
