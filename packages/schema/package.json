{
  "name": "mergora-schema",
  "version": "0.0.0",
  "private": true,
  "description": "Versioned Mergora schemas, TypeScript contracts, and bounded runtime validators",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AkhilTrivediX/mergora.git",
    "directory": "packages/schema"
  },
  "homepage": "https://akhiltrivedix.github.io/mergora/",
  "bugs": "https://github.com/AkhilTrivediX/mergora/issues",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "import": "./dist/packages/schema/src/index.js"
    },
    "./schemas/*": "./dist/registry/schemas/*"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/packages/schema/src/index.d.ts",
        "import": "./dist/packages/schema/src/index.js"
      },
      "./schemas/*": "./dist/registry/schemas/*"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "typescript": "catalog:"
  }
}
