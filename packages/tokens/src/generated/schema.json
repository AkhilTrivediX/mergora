  "additionalProperties": {
    "anyOf": [
      {
        "$ref": "#/$defs/token"
      },
      {
        "$ref": "#/$defs/group"
      }
    ]
  },
  "description": "Structural schema for the Mergora-supported DTCG 2025.10 token types. Compiler validation applies stricter value and reference rules.",
