{
  "$description": "Canonical Mergora Living Workbench tokens with aliases for the light and comfortable default context.",
  "$extensions": {
    "org.mergora.contract": {
      "contractVersion": "1.0.0",
      "defaultContext": {
        "density": "comfortable",
        "theme": "light"
      },
      "resolver": "mergora.resolver.json"
    }
