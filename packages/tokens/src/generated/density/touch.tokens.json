{
  "$description": "Touch density preserves at least 48px primary control and row dimensions.",
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "semantic": {
    "density": {
      "controlGap": {
        "$type": "dimension",
        "$value": "{primitive.space.3}"
      },
      "controlHeight": {
        "$type": "dimension",
        "$value": "{primitive.size.12}"
      },
      "controlPaddingInline": {
        "$type": "dimension",
        "$value": "{primitive.space.4}"
      },
      "panelPadding": {
        "$type": "dimension",
        "$value": "{primitive.space.5}"
      },
      "rowHeight": {
        "$type": "dimension",
        "$value": "{primitive.size.12}"
      }
    }
  }
}
