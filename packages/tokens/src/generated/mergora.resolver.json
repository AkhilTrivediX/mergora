{
  "$schema": "https://www.designtokens.org/schemas/2025.10/resolver.json",
  "description": "Orthogonal theme and density resolution for the Mergora token contract.",
  "modifiers": {
    "density": {
      "contexts": {
        "comfortable": [
          {
            "$ref": "density/comfortable.tokens.json"
          }
        ],
        "compact": [
          {
            "$ref": "density/compact.tokens.json"
          }
        ],
        "touch": [
          {
            "$ref": "density/touch.tokens.json"
          }
        ]
      },
      "default": "comfortable",
      "description": "Control and layout density independent from color theme."
    },
    "theme": {
      "contexts": {
        "dark": [
          {
            "$ref": "themes/dark.tokens.json"
          }
        ],
        "enhanced-contrast": [
          {
            "$ref": "themes/light.tokens.json"
          },
          {
            "$ref": "themes/enhanced-contrast.tokens.json"
          }
        ],
        "forced-colors": [
          {
            "$ref": "themes/light.tokens.json"
          },
          {
            "$ref": "themes/forced-colors.tokens.json"
          }
        ],
        "light": [
          {
            "$ref": "themes/light.tokens.json"
          }
        ]
      },
      "default": "light",
      "description": "Explicit color themes and forced-color fallback intent."
    }
  },
  "name": "Mergora Living Workbench",
  "resolutionOrder": [
    {
      "$ref": "#/sets/foundation"
    },
    {
      "$ref": "#/modifiers/theme"
    },
    {
      "$ref": "#/modifiers/density"
    }
  ],
  "sets": {
    "foundation": {
      "description": "Primitive values followed by semantic and component aliases.",
      "sources": [
        {
          "$ref": "primitives.tokens.json"
        },
        {
          "$ref": "semantics.tokens.json"
        }
      ]
    }
  },
  "version": "2025.10"
}
