{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://akhiltrivedix.github.io/mergora/r/v1/schemas/executable-contract-v1.schema.json",
  "title": "Mergora executable Contract definition v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "contractVersion",
    "contractId",
    "registryId",
    "itemId",
    "payloadDigest",
    "conformanceClaim",
    "limitations",
    "assertions"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "contractVersion": { "$ref": "#/$defs/semver" },
    "contractId": { "$ref": "#/$defs/catalogId" },
    "registryId": { "$ref": "#/$defs/catalogId" },
    "itemId": { "$ref": "#/$defs/catalogId" },
    "payloadDigest": { "$ref": "#/$defs/sha256" },
    "conformanceClaim": { "const": "automated-evidence-only" },
    "limitations": {
      "type": "array",
      "items": { "$ref": "#/$defs/nonEmptyText" },
      "uniqueItems": true
    },
    "assertions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/assertion" }
    }
  },
  "$defs": {
    "catalogId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "maxLength": 128
    },
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
    },
    "sha256": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "nonEmptyText": { "type": "string", "minLength": 1, "maxLength": 1024 },
    "ownedFileTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "logicalPath"],
      "properties": {
        "kind": { "const": "owned-file" },
        "logicalPath": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*(?:/[A-Za-z0-9][A-Za-z0-9._-]*)*$",
          "maxLength": 512
        }
      }
    },
    "assertionBase": {
      "type": "object",
      "required": [
        "id",
        "mode",
        "evidenceType",
        "target",
        "expectedBehavior",
        "severity",
        "remediationUrl",
        "adapter"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/catalogId" },
        "mode": { "enum": ["a11y", "browser", "keyboard", "responsive", "static"] },
        "evidenceType": {
          "enum": [
            "accessibility-tree",
            "browser-behavior",
            "keyboard-behavior",
            "responsive-geometry",
            "static-source"
          ]
        },
        "target": { "$ref": "#/$defs/ownedFileTarget" },
        "expectedBehavior": { "$ref": "#/$defs/nonEmptyText" },
        "severity": { "enum": ["S0", "S1", "S2", "S3"] },
        "remediationUrl": { "type": "string", "format": "uri", "pattern": "^https://" }
      }
    },
    "staticAdapter": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "version"],
          "properties": {
            "kind": { "const": "file-exists" },
            "version": { "const": "1.0.0" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "version", "value"],
          "properties": {
            "kind": { "enum": ["text-includes", "text-excludes"] },
            "version": { "const": "1.0.0" },
            "value": { "type": "string", "minLength": 1, "maxLength": 8192 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "version", "pointer", "expected"],
          "properties": {
            "kind": { "const": "json-pointer-equals" },
            "version": { "const": "1.0.0" },
            "pointer": { "type": "string", "pattern": "^(?:$|/)", "maxLength": 512 },
            "expected": {}
          }
        }
      ]
    },
    "harnessAdapter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "version", "harnessId"],
      "properties": {
        "kind": { "const": "harness" },
        "version": { "const": "1.0.0" },
        "harnessId": { "$ref": "#/$defs/catalogId" }
      }
    },
    "assertion": {
      "allOf": [
        { "$ref": "#/$defs/assertionBase" },
        {
          "if": { "properties": { "mode": { "const": "static" } }, "required": ["mode"] },
          "then": {
            "properties": {
              "evidenceType": { "const": "static-source" },
              "adapter": { "$ref": "#/$defs/staticAdapter" }
            }
          },
          "else": {
            "properties": { "adapter": { "$ref": "#/$defs/harnessAdapter" } },
            "allOf": [
              {
                "if": { "properties": { "mode": { "const": "a11y" } } },
                "then": { "properties": { "evidenceType": { "const": "accessibility-tree" } } }
              },
              {
                "if": { "properties": { "mode": { "const": "browser" } } },
                "then": { "properties": { "evidenceType": { "const": "browser-behavior" } } }
              },
              {
                "if": { "properties": { "mode": { "const": "keyboard" } } },
                "then": { "properties": { "evidenceType": { "const": "keyboard-behavior" } } }
              },
              {
                "if": { "properties": { "mode": { "const": "responsive" } } },
                "then": { "properties": { "evidenceType": { "const": "responsive-geometry" } } }
              }
            ]
          }
        },
        { "unevaluatedProperties": false }
      ]
    }
  }
}
