{
  "$schema": "./mergora-contract.schema.json",
  "contractVersion": "1.1.0",
  "dtcgVersion": "2025.10",
  "cssVariablePrefix": "mrg",
  "defaultContext": { "theme": "light", "density": "comfortable" },
  "requiredContexts": {
    "theme": ["light", "dark", "enhanced-contrast", "forced-colors"],
    "density": ["comfortable", "compact", "touch"]
  },
  "semanticColorGroups": [
    "accent",
    "action",
    "background",
    "border",
    "brand",
    "code",
    "diff",
    "focus",
    "foreground",
    "overlay",
    "selection",
    "status"
  ],
  "requiredTokenPrefixes": [
    "primitive.color",
    "primitive.font",
    "primitive.space",
    "primitive.size",
    "primitive.radius",
    "primitive.border",
    "primitive.shadow",
    "primitive.layer",
    "primitive.opacity",
    "primitive.duration",
    "primitive.easing",
    "primitive.breakpoint",
    "primitive.container",
    "semantic.color",
    "semantic.font",
    "semantic.space",
    "semantic.size",
    "semantic.radius",
    "semantic.border",
    "semantic.elevation",
    "semantic.focus",
    "semantic.layer",
    "semantic.opacity",
    "semantic.motion",
    "semantic.density",
    "semantic.breakpoint",
    "semantic.container",
    "component"
  ],
  "brandAnchors": {
    "livingGreen": {
      "path": "primitive.color.green.500",
      "components": [0.6, 0.158, 150]
    },
    "actionGreen": {
      "path": "primitive.color.green.700",
      "components": [0.42, 0.13, 150]
    },
    "deepViolet": {
      "path": "primitive.color.violet.700",
      "components": [0.33, 0.135, 292]
    },
    "canvas": {
      "path": "primitive.color.neutral.0",
      "components": [1, 0, 0]
    },
    "surface": {
      "path": "primitive.color.neutral.50",
      "components": [0.97, 0.006, 150]
    },
    "ink": {
      "path": "primitive.color.neutral.800",
      "components": [0.18, 0.018, 150]
    },
    "mutedInk": {
      "path": "primitive.color.neutral.500",
      "components": [0.47, 0.018, 150]
    },
    "line": {
      "path": "primitive.color.neutral.200",
      "components": [0.875, 0.01, 150]
    }
  },
