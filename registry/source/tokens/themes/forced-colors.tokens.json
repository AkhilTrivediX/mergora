{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "Forced-colors fallback values and CSS system-color intent. The compiler emits system colors inside forced-colors media queries while retaining valid DTCG color fallbacks.",
  "semantic": {
    "color": {
      "background": {
        "$type": "color",
        "canvas": {
          "$value": "{primitive.color.neutral.0}",
          "$extensions": { "org.mergora.forcedColors": { "cssSystemColor": "Canvas" } }
        },
        "surface": {
          "$value": "{primitive.color.neutral.0}",
          "$extensions": { "org.mergora.forcedColors": { "cssSystemColor": "Canvas" } }
        },
        "surfaceRaised": {
          "$value": "{primitive.color.neutral.0}",
          "$extensions": { "org.mergora.forcedColors": { "cssSystemColor": "Canvas" } }
        },
        "surfaceSunken": {
          "$value": "{primitive.color.neutral.0}",
          "$extensions": { "org.mergora.forcedColors": { "cssSystemColor": "Canvas" } }
        },
        "inverse": {
          "$value": "{primitive.color.neutral.900}",
          "$extensions": { "org.mergora.forcedColors": { "cssSystemColor": "CanvasText" } }
        }
      },
      "foreground": {
