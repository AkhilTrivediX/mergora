        "background": {
          "$value": "{primitive.color.green.100}",
          "$extensions": { "org.mergora.forcedColors": { "cssSystemColor": "Highlight" } }
        },
        "foreground": {
          "$value": "{primitive.color.green.900}",
          "$extensions": { "org.mergora.forcedColors": { "cssSystemColor": "HighlightText" } }
        },
        "border": {
          "$value": "{primitive.color.green.800}",
          "$extensions": { "org.mergora.forcedColors": { "cssSystemColor": "Highlight" } }
        }
      },
      "focus": {
        "$type": "color",
