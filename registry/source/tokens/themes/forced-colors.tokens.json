          "$extensions": { "org.mergora.forcedColors": { "cssSystemColor": "Canvas" } }
        },
        "disabled": {
          "$value": "{primitive.color.neutral.600}",
          "$extensions": { "org.mergora.forcedColors": { "cssSystemColor": "GrayText" } }
        }
      },
      "border": {
        "$type": "color",
        "default": {
          "$value": "{primitive.color.neutral.600}",
          "$extensions": { "org.mergora.forcedColors": { "cssSystemColor": "CanvasText" } }
        },
        "strong": {
          "$value": "{primitive.color.neutral.800}",
          "$extensions": { "org.mergora.forcedColors": { "cssSystemColor": "CanvasText" } }
        },
        "interactive": {
          "$value": "{primitive.color.neutral.800}",
          "$extensions": { "org.mergora.forcedColors": { "cssSystemColor": "ButtonBorder" } }
