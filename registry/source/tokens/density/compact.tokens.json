{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "Compact density for data-heavy pointer interfaces. It is not the default for touch-only controls.",
  "semantic": {
    "density": {
      "controlHeight": { "$type": "dimension", "$value": "{primitive.size.8}" },
      "controlPaddingInline": { "$type": "dimension", "$value": "{primitive.space.2}" },
      "controlGap": { "$type": "dimension", "$value": "{primitive.space.1}" },
      "rowHeight": { "$type": "dimension", "$value": "{primitive.size.8}" },
      "panelPadding": { "$type": "dimension", "$value": "{primitive.space.3}" }
    }
  }
}
