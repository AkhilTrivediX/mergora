        "3xl": { "$value": { "value": 32, "unit": "px" } },
        "4xl": { "$value": { "value": 40, "unit": "px" } }
      },
      "lineHeight": {
        "$type": "number",
        "tight": { "$value": 1.15 },
        "heading": { "$value": 1.25 },
        "body": { "$value": 1.55 },
        "code": { "$value": 1.6 }
      },
      "letterSpacing": {
        "$type": "dimension",
        "tight": { "$value": { "value": -0.4, "unit": "px" } },
        "normal": { "$value": { "value": 0, "unit": "px" } },
        "code": { "$value": { "value": 0.1, "unit": "px" } }
      },
      "typography": {
        "$type": "typography",
        "body": {
          "$value": {
            "fontFamily": [
              "Schibsted Grotesk",
              "Schibsted Grotesk Fallback",
              "Arial",
              "sans-serif"
            ],
            "fontSize": { "value": 16, "unit": "px" },
            "fontWeight": 400,
            "letterSpacing": { "value": 0, "unit": "px" },
            "lineHeight": 1.55
          }
        },
        "heading": {
          "$value": {
            "fontFamily": [
              "Schibsted Grotesk",
              "Schibsted Grotesk Fallback",
              "Arial",
              "sans-serif"
            ],
            "fontSize": { "value": 32, "unit": "px" },
            "fontWeight": 650,
            "letterSpacing": { "value": -0.4, "unit": "px" },
            "lineHeight": 1.15
          }
        },
        "code": {
          "$value": {
            "fontFamily": [
              "Commit Mono",
              "Commit Mono Fallback",
              "ui-monospace",
              "Consolas",
              "monospace"
            ],
            "fontSize": { "value": 14, "unit": "px" },
            "fontWeight": 450,
            "letterSpacing": { "value": 0.1, "unit": "px" },
            "lineHeight": 1.6
          }
        }
      }
    },
    "space": {
      "$type": "dimension",
      "0": { "$value": { "value": 0, "unit": "px" } },
      "1": { "$value": { "value": 4, "unit": "px" } },
      "2": { "$value": { "value": 8, "unit": "px" } },
      "3": { "$value": { "value": 12, "unit": "px" } },
      "4": { "$value": { "value": 16, "unit": "px" } },
      "5": { "$value": { "value": 20, "unit": "px" } },
      "6": { "$value": { "value": 24, "unit": "px" } },
      "8": { "$value": { "value": 32, "unit": "px" } },
