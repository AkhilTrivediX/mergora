    "font": {
      "family": {
        "$type": "fontFamily",
        "prose": {
          "$value": ["Schibsted Grotesk", "Schibsted Grotesk Fallback", "Arial", "sans-serif"]
        },
        "machine": {
          "$value": [
            "Commit Mono",
            "Commit Mono Fallback",
            "ui-monospace",
            "SFMono-Regular",
            "Consolas",
            "monospace"
          ]
        }
      },
      "weight": {
        "$type": "fontWeight",
        "regular": { "$value": 400 },
        "code": { "$value": 450 },
        "medium": { "$value": 550 },
        "semibold": { "$value": 650 },
        "bold": { "$value": 750 }
      },
      "size": {
        "$type": "dimension",
        "xs": { "$value": { "value": 12, "unit": "px" } },
        "sm": { "$value": { "value": 14, "unit": "px" } },
        "md": { "$value": { "value": 16, "unit": "px" } },
        "lg": { "$value": { "value": 18, "unit": "px" } },
