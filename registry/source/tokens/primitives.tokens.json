        "$value": {
          "color": { "colorSpace": "oklch", "components": [0.12, 0.018, 150], "alpha": 0.2 },
          "offsetX": { "value": 0, "unit": "px" },
          "offsetY": { "value": 6, "unit": "px" },
          "blur": { "value": 8, "unit": "px" },
          "spread": { "value": -2, "unit": "px" }
        }
      }
    },
    "layer": {
      "$type": "number",
      "base": { "$value": 0 },
      "raised": { "$value": 10 },
      "sticky": { "$value": 100 },
      "dropdown": { "$value": 200 },
      "overlay": { "$value": 300 },
      "modal": { "$value": 400 },
      "toast": { "$value": 500 },
      "tooltip": { "$value": 600 }
