      "violet": {
        "$type": "color",
        "50": { "$value": { "colorSpace": "oklch", "components": [0.97, 0.02, 292] } },
        "100": { "$value": { "colorSpace": "oklch", "components": [0.91, 0.05, 292] } },
        "200": { "$value": { "colorSpace": "oklch", "components": [0.82, 0.09, 292] } },
        "300": { "$value": { "colorSpace": "oklch", "components": [0.72, 0.13, 292] } },
        "400": { "$value": { "colorSpace": "oklch", "components": [0.62, 0.16, 292] } },
        "500": { "$value": { "colorSpace": "oklch", "components": [0.52, 0.17, 292] } },
        "600": { "$value": { "colorSpace": "oklch", "components": [0.42, 0.155, 292] } },
