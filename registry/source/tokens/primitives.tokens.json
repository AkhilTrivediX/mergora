        "0": { "$value": { "colorSpace": "oklch", "components": [1, 0, 0] } },
        "25": { "$value": { "colorSpace": "oklch", "components": [0.985, 0.002, 150] } },
        "50": { "$value": { "colorSpace": "oklch", "components": [0.97, 0.006, 150] } },
        "100": { "$value": { "colorSpace": "oklch", "components": [0.94, 0.008, 150] } },
        "200": { "$value": { "colorSpace": "oklch", "components": [0.875, 0.01, 150] } },
        "300": { "$value": { "colorSpace": "oklch", "components": [0.78, 0.014, 150] } },
        "400": { "$value": { "colorSpace": "oklch", "components": [0.62, 0.018, 150] } },
