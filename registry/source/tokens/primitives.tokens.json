    "opacity": {
      "$type": "number",
      "disabled": { "$value": 0.48 },
      "muted": { "$value": 0.68 },
      "scrim": { "$value": 0.56 },
      "solid": { "$value": 1 }
    },
    "duration": {
      "$type": "duration",
      "instant": { "$value": { "value": 0, "unit": "ms" } },
      "reduced": { "$value": { "value": 1, "unit": "ms" } },
      "fast": { "$value": { "value": 80, "unit": "ms" } },
      "normal": { "$value": { "value": 160, "unit": "ms" } },
      "slow": { "$value": { "value": 240, "unit": "ms" } },
      "deliberate": { "$value": { "value": 360, "unit": "ms" } }
    },
    "easing": {
      "$type": "cubicBezier",
      "linear": { "$value": [0, 0, 1, 1] },
      "standard": { "$value": [0.2, 0, 0, 1] },
      "enter": { "$value": [0, 0, 0.2, 1] },
      "exit": { "$value": [0.4, 0, 1, 1] }
