        "300": { "$value": { "colorSpace": "oklch", "components": [0.75, 0.14, 150] } },
        "400": { "$value": { "colorSpace": "oklch", "components": [0.67, 0.16, 150] } },
        "500": {
          "$description": "Living Green brand target.",
          "$value": { "colorSpace": "oklch", "components": [0.6, 0.158, 150] }
