    { "name": "agenda", "element": "section", "slot": "scheduler-agenda" },
    { "name": "editor", "element": "section", "slot": "scheduler-editor" },
    { "name": "conflicts", "element": "section", "slot": "scheduler-conflicts" }
  ]
