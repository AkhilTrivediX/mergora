    },
    {
      "element": "div role=treeitem",
      "slot": "json-tree-item",
      "stableAttributes": ["data-slot", "data-expanded", "data-selected", "data-type", "data-path"]
    },
    {
      "element": "button",
      "slot": "json-copy-path",
      "stableAttributes": ["data-slot", "data-copy-status"]
    },
    {
      "element": "button",
      "slot": "json-copy-value",
      "stableAttributes": ["data-slot", "data-copy-status"]
    }
  ]
}
