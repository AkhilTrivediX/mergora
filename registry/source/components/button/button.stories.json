    {
      "id": "read-only",
      "applicability": {
        "status": "not-applicable",
        "reason": "Native buttons do not expose a read-only state; use disabled or pending according to the interaction contract."
      }
    },
    {
      "id": "invalid",
      "applicability": {
        "status": "not-applicable",
        "reason": "Validation state belongs to the owning field or form, not to a standalone action button."
      }
    },
    {
      "id": "required",
      "applicability": {
        "status": "not-applicable",
        "reason": "The native required attribute does not apply to button elements."
      }
