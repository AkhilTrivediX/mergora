      "story": "Pending"
    },
    {
      "id": "empty",
      "applicability": {
        "status": "not-applicable",
        "reason": "An unnamed empty button is invalid usage and receives a development diagnostic rather than a supported state."
      }
    },
    {
      "id": "populated",
      "applicability": { "status": "applicable" },
      "story": "Default"
    },
    {
      "id": "partial",
      "applicability": {
        "status": "not-applicable",
        "reason": "Button has no partial data model; pending represents an in-flight activation."
      }
    },
    {
      "id": "success",
      "applicability": {
        "status": "not-applicable",
        "reason": "Action outcome belongs in persistent workflow feedback; Button does not encode success as a control state."
      }
    },
    {
      "id": "warning",
      "applicability": {
        "status": "not-applicable",
        "reason": "Warnings require adjacent explanatory content and are not represented by a color-only Button variant."
      }
    },
    {
      "id": "error",
      "applicability": {
        "status": "not-applicable",
        "reason": "Errors belong to the workflow or field that failed; Button does not hold an error state."
