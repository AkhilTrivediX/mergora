{
  "schemaVersion": 1,
  "itemId": "button",
  "entryExport": "Button",
  "refTarget": "HTMLButtonElement",
  "nativeProps": "React.ButtonHTMLAttributes<HTMLButtonElement>",
  "defaultNativeType": "button",
  "exports": [
    { "kind": "component", "name": "Button" },
    { "kind": "type", "name": "ButtonOwnProps" },
    { "kind": "type", "name": "ButtonProps" },
    { "kind": "type", "name": "ButtonSize" },
    { "kind": "type", "name": "ButtonVariant" }
  ],
  "controlledState": [],
  "props": [
    {
      "default": "primary",
      "name": "variant",
      "required": false,
      "type": "primary | secondary | quiet | destructive"
    },
    {
      "default": "medium",
      "name": "size",
      "required": false,
      "type": "small | medium | large"
    },
    { "default": false, "name": "pending", "required": false, "type": "boolean" },
    {
      "default": "original visible label",
      "name": "pendingLabel",
      "required": false,
      "type": "string"
    }
  ],
  "eventPolicy": {
