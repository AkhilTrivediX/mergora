{
  "schemaVersion": 1,
  "itemId": "checkbox-group",
  "riskClass": 2,
  "serverBoundary": "client-island",
  "directions": ["ltr", "rtl"],
  "locales": ["en-US", "de-DE", "ar-EG", "he-IL", "ja-JP", "hi-IN", "en-XA", "ar-XB"],
  "inputModalities": ["keyboard", "mouse", "touch", "screen-reader", "speech", "switch"],
  "themes": ["light", "dark", "enhanced-contrast", "forced-colors"],
  "densities": ["comfortable", "compact", "touch"],
  "stateGroups": [
    "default",
    "empty",
    "partial",
    "invalid",
    "required",
    "disabled",
    "minimum",
    "maximum",
    "reset",
    "rtl"
  ],
  "slots": [
    {
      "name": "checkbox-group",
      "semanticElement": "fieldset",
      "refTarget": "HTMLFieldSetElement",
      "states": ["disabled", "invalid", "layout"]
    },
    {
      "name": "checkbox-group-label",
      "semanticElement": "legend",
      "refTarget": "none",
      "states": ["visible"]
    },
    {
      "name": "checkbox-group-items",
      "semanticElement": "div",
      "refTarget": "none",
      "states": ["empty", "populated"]
    },
    {
      "name": "checkbox-group-error",
      "semanticElement": "p",
      "refTarget": "none",
      "states": ["invalid"]
    }
  ],
  "contract": { "id": "checkbox-group-accessibility", "version": "0.1.0" },
  "passport": { "id": "checkbox-group-quality-passport", "version": "0.0.0" }
}
