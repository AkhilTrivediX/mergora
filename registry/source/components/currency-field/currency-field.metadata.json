{
  "schemaVersion": 1,
  "itemId": "currency-field",
  "riskClass": 2,
  "serverBoundary": "client-island",
  "directions": ["ltr", "rtl"],
  "locales": ["en-US", "de-DE", "ar-EG", "he-IL", "ja-JP", "hi-IN", "en-XA", "ar-XB"],
  "inputModalities": ["keyboard", "mouse", "touch", "screen-reader", "speech", "switch"],
  "themes": ["light", "dark", "enhanced-contrast", "forced-colors"],
  "densities": ["comfortable", "compact", "touch"],
  "stateGroups": [
    "default",
    "focus-visible",
    "disabled",
    "read-only",
    "invalid",
    "required",
    "empty",
    "populated",
    "negative",
    "rtl"
  ],
  "slots": [
    {
      "name": "currency-field",
      "semanticElement": "div",
      "refTarget": "HTMLDivElement",
      "states": ["currency", "disabled", "invalid", "read-only", "required"]
    },
    {
      "name": "number-field-group",
      "semanticElement": "div",
      "refTarget": "none",
      "states": ["focus-within", "disabled", "invalid"]
    },
    {
      "name": "number-field-input",
      "semanticElement": "input spinbutton",
      "refTarget": "HTMLInputElement through inputRef",
      "states": ["empty", "populated", "negative"]
    },
    {
      "name": "number-field-decrement",
      "semanticElement": "button",
      "refTarget": "none",
      "states": ["disabled", "pressed"]
    },
    {
      "name": "number-field-increment",
      "semanticElement": "button",
      "refTarget": "none",
      "states": ["disabled", "pressed"]
    },
    {
      "name": "number-field-scrub",
      "semanticElement": "button",
      "refTarget": "none",
      "states": ["disabled", "pressed"]
    }
  ],
  "contract": { "id": "currency-field-accessibility", "version": "0.1.0" },
  "passport": { "id": "currency-field-quality-passport", "version": "0.0.0" }
}
