{
  "schemaVersion": 1,
  "itemId": "slider",
  "riskClass": 2,
  "serverBoundary": "client-island",
  "directions": ["ltr", "rtl"],
  "locales": ["en-US", "de-DE", "ar-EG", "he-IL", "ja-JP", "hi-IN", "en-XA", "ar-XB"],
  "inputModalities": ["keyboard", "mouse", "touch", "screen-reader", "speech", "switch"],
  "themes": ["light", "dark", "enhanced-contrast", "forced-colors"],
  "densities": ["comfortable", "compact", "touch"],
  "stateGroups": [
    "default",
    "hover",
    "dragging",
    "focus-visible",
    "disabled",
    "read-only",
    "invalid",
    "controlled",
    "uncontrolled",
    "horizontal",
    "vertical",
    "rtl"
  ],
  "slots": [
    {
      "name": "slider",
      "semanticElement": "div",
      "refTarget": "HTMLDivElement",
      "states": ["disabled", "read-only", "invalid"]
    },
    {
      "name": "slider-output",
      "semanticElement": "output",
      "refTarget": "none",
      "states": ["formatted"]
    },
    {
      "name": "slider-readonly-status",
      "semanticElement": "visually hidden span",
      "refTarget": "none",
      "states": ["read-only"]
    },
    {
      "name": "slider-track",
      "semanticElement": "div",
      "refTarget": "none",
      "states": ["horizontal", "vertical", "hover", "dragging"]
    },
    {
      "name": "slider-fill",
      "semanticElement": "div",
      "refTarget": "none",
      "states": ["disabled", "invalid"]
    },
    {
      "name": "slider-thumb",
      "semanticElement": "input type=range with slider role",
      "refTarget": "none",
      "states": ["focus-visible", "dragging", "disabled", "read-only", "invalid"]
    },
    {
      "name": "slider-marks",
      "semanticElement": "visual tick labels",
      "refTarget": "none",
      "states": ["horizontal", "vertical", "narrow"]
    }
  ],
  "contract": { "id": "slider-accessibility", "version": "0.1.0" },
  "passport": { "id": "slider-quality-passport", "version": "0.0.0" }
}
