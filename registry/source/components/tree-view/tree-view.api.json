    { "kind": "type", "name": "TreeViewItem" },
    { "kind": "type", "name": "TreeViewLoadError" },
    { "kind": "type", "name": "TreeViewMoveActions" },
    { "kind": "type", "name": "TreeViewMoveDirection" },
