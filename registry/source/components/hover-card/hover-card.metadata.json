{
  "schemaVersion": 1,
  "itemId": "hover-card",
  "riskClass": 2,
  "serverBoundary": "client-island",
  "directions": ["ltr", "rtl"],
  "locales": ["en-US", "de-DE", "ar-EG", "he-IL", "ja-JP", "hi-IN", "en-XA", "ar-XB"],
  "inputModalities": ["keyboard", "mouse", "touch", "screen-reader", "speech", "switch"],
  "themes": ["light", "dark", "enhanced-contrast", "forced-colors"],
  "densities": ["comfortable", "compact", "touch"],
  "stateGroups": [
    "default",
    "enhancement-disabled",
    "enhancement-enabled",
    "closed",
    "open",
    "narrow",
    "rtl",
    "forced-colors",
    "reduced-motion"
  ],
  "slots": [
    {
      "name": "hover-card-trigger",
      "semanticElement": "button",
      "refTarget": "HTMLButtonElement",
      "states": ["closed", "open", "disabled"]
    },
    {
      "name": "hover-card-content",
      "semanticElement": "div role=dialog",
      "refTarget": "HTMLDivElement",
      "states": ["closed", "open", "pinned"]
    },
    {
      "name": "hover-card-pin-rail",
      "semanticElement": "status rail",
      "refTarget": "none",
      "states": ["enhancement-enabled", "pinned"]
    }
  ],
  "contract": {
    "id": "hover-card-accessibility",
    "version": "0.1.0"
  },
  "passport": {
    "id": "hover-card-quality-passport",
    "version": "0.0.0"
  }
}
