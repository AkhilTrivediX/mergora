{
  "schemaVersion": 1,
  "itemId": "textarea",
  "riskClass": 1,
  "serverBoundary": "client-island",
  "directions": ["ltr", "rtl"],
  "locales": ["en-US", "de-DE", "ar-EG", "he-IL", "ja-JP", "hi-IN", "en-XA", "ar-XB"],
  "inputModalities": ["keyboard", "mouse", "touch", "screen-reader", "speech", "switch"],
  "themes": ["light", "dark", "enhanced-contrast", "forced-colors"],
  "densities": ["comfortable", "compact", "touch"],
  "stateGroups": [
    "default",
    "focus-visible",
    "disabled",
    "invalid",
    "required",
    "composition",
    "autogrow",
    "count",
    "rtl"
  ],
  "slots": [
    {
      "name": "textarea-root",
      "semanticElement": "span",
      "refTarget": "none",
      "states": ["disabled", "invalid", "autogrow"]
    },
    {
      "name": "textarea",
      "semanticElement": "textarea",
      "refTarget": "HTMLTextAreaElement",
      "states": ["required", "invalid", "disabled", "composing"]
    },
    {
      "name": "textarea-count",
      "semanticElement": "output",
      "refTarget": "none",
      "states": ["present"]
    }
  ],
  "contract": { "id": "textarea-accessibility", "version": "0.1.0" },
  "passport": { "id": "textarea-quality-passport", "version": "0.0.0" }
}
