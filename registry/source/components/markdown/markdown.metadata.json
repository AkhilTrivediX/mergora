{
  "schemaVersion": 1,
  "itemId": "markdown",
  "riskClass": 2,
  "serverBoundary": "server-compatible",
  "directions": ["ltr", "rtl"],
  "locales": ["en-US", "de-DE", "ar-EG", "he-IL", "ja-JP", "hi-IN", "en-XA", "ar-XB"],
  "inputModalities": ["keyboard", "mouse", "touch", "screen-reader", "speech", "switch"],
  "themes": ["light", "dark", "enhanced-contrast", "forced-colors"],
  "densities": ["comfortable", "compact", "touch"],
  "stateGroups": [
    "default",
    "enhancement-disabled",
    "enhancement-enabled",
    "empty",
    "populated",
    "literal-text",
    "consumer-adapter",
    "streaming",
    "complete",
    "narrow",
    "rtl",
    "forced-colors",
    "reduced-motion"
  ],
  "slots": [
    {
      "name": "markdown",
      "semanticElement": "article",
      "refTarget": "HTMLElement",
      "states": ["empty", "populated", "streaming", "complete"]
    },
    {
      "name": "markdown-content",
      "semanticElement": "div",
      "refTarget": "none",
      "states": ["literal-text", "consumer-adapter"]
    },
    {
      "name": "markdown-renderer-boundary",
      "semanticElement": "optional paragraph",
      "refTarget": "none",
      "states": ["enhancement-enabled"]
    }
  ],
  "contract": { "id": "markdown-accessibility", "version": "0.1.0" },
  "passport": { "id": "markdown-quality-passport", "version": "0.0.0" }
}
