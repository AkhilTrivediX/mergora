{
  "schemaVersion": 1,
  "itemId": "image",
  "riskClass": 1,
  "serverBoundary": "client-island",
  "directions": ["ltr", "rtl"],
  "locales": ["en-US", "de-DE", "ar-EG", "he-IL", "ja-JP", "hi-IN", "en-XA", "ar-XB"],
  "inputModalities": ["keyboard", "mouse", "touch", "screen-reader", "speech", "switch"],
  "themes": ["light", "dark", "enhanced-contrast", "forced-colors"],
  "densities": ["comfortable", "compact", "touch"],
  "stateGroups": [
    "default",
    "enhancement-disabled",
    "enhancement-enabled",
    "loading",
    "loaded",
    "error",
    "rejected",
    "decorative",
    "narrow",
    "rtl",
    "forced-colors",
    "reduced-motion"
  ],
  "slots": [
    {
      "name": "image",
      "semanticElement": "figure",
      "refTarget": "HTMLElement",
      "states": ["loading", "loaded", "error", "rejected"]
    },
    {
      "name": "image-media",
      "semanticElement": "img",
      "refTarget": "none",
      "states": ["loading", "loaded", "error"]
    },
    {
      "name": "image-fallback",
      "semanticElement": "conditional div",
      "refTarget": "none",
      "states": ["error", "rejected"]
    },
    {
      "name": "image-status",
      "semanticElement": "optional figcaption status",
      "refTarget": "none",
      "states": ["enhancement-enabled"]
    }
  ],
  "contract": { "id": "image-accessibility", "version": "0.1.0" },
  "passport": { "id": "image-quality-passport", "version": "0.0.0" }
}
