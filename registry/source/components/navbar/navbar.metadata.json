    },
    {
      "name": "navbar-mobile",
      "semanticElement": "responsive nav",
      "refTarget": "none",
      "states": ["open", "focus-visible"]
    },
    {
      "name": "navbar-route-status",
      "semanticElement": "optional output",
      "refTarget": "none",
      "states": ["loading", "error"]
    }
  ],
  "contract": { "id": "navbar-accessibility", "version": "0.1.0" },
  "passport": { "id": "navbar-quality-passport", "version": "0.0.0" }
}
