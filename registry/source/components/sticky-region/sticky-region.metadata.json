{
  "schemaVersion": 1,
  "itemId": "sticky-region",
  "riskClass": 2,
  "serverBoundary": "client-island",
  "directions": ["ltr", "rtl"],
  "locales": ["en-US", "de-DE", "ar-EG", "he-IL", "ja-JP", "hi-IN", "en-XA", "ar-XB"],
  "inputModalities": ["keyboard", "mouse", "touch", "screen-reader", "speech", "switch"],
  "themes": ["light", "dark", "enhanced-contrast", "forced-colors"],
  "densities": ["comfortable", "compact", "touch"],
  "stateGroups": [
    "block-start",
    "block-end",
    "contained",
    "page",
    "safe-area",
    "measured",
    "focus-not-obscured",
    "zoom",
    "rtl"
  ],
  "slots": [
    {
      "name": "sticky-region-root",
      "semanticElement": "div",
      "refTarget": "HTMLDivElement",
      "states": ["position", "contained", "offset", "safe-area", "size"]
    },
    {
      "name": "sticky-region-content",
      "semanticElement": "div | header | footer",
      "refTarget": "HTMLElement",
      "states": ["position", "element"]
    },
    {
      "name": "sticky-region-body",
      "semanticElement": "div",
      "refTarget": "HTMLDivElement",
      "states": ["position"]
    }
  ],
  "contract": { "id": "sticky-region-accessibility", "version": "0.1.0" },
  "passport": { "id": "sticky-region-quality-passport", "version": "0.0.0" }
}
