    { "kind": "type", "name": "StickyRegionBodyProps" },
    { "kind": "type", "name": "StickyRegionContentProps" },
    { "kind": "type", "name": "StickyRegionElement" },
    { "kind": "type", "name": "StickyRegionOffset" },
    { "kind": "type", "name": "StickyRegionPosition" },
    { "kind": "type", "name": "StickyRegionRootProps" },
    { "kind": "type", "name": "StickyRegionSize" }
  ],
  "rootProps": [
