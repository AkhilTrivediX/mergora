{
  "schemaVersion": 1,
  "itemId": "search-field",
  "riskClass": 2,
  "serverBoundary": "client-island",
  "directions": ["ltr", "rtl"],
  "locales": ["en-US", "de-DE", "ar-EG", "he-IL", "ja-JP", "hi-IN", "en-XA", "ar-XB"],
  "inputModalities": ["keyboard", "mouse", "touch", "screen-reader", "speech", "switch"],
  "themes": ["light", "dark", "enhanced-contrast", "forced-colors"],
  "densities": ["comfortable", "compact", "touch"],
  "stateGroups": [
    "default",
    "focus-visible",
    "empty-query",
    "populated-query",
    "loading",
    "results",
    "no-results",
    "error",
    "disabled",
    "read-only",
    "invalid",
    "required",
    "composing",
    "rtl"
  ],
  "slots": [
    {
      "name": "search-field",
      "semanticElement": "span",
      "refTarget": "none",
      "states": [
        "empty",
        "disabled",
        "read-only",
        "invalid",
        "idle",
        "loading",
        "results",
        "no-results",
        "error"
      ]
    },
    {
      "name": "search-field-input",
      "semanticElement": "input type=search",
      "refTarget": "HTMLInputElement",
      "states": ["empty", "populated", "required", "invalid", "disabled", "read-only", "composing"]
    },
    {
      "name": "search-field-clear",
      "semanticElement": "button",
      "refTarget": "none",
      "states": ["available", "disabled", "hidden-empty", "disabled-composing"]
    },
    {
      "name": "search-field-submit",
      "semanticElement": "button",
      "refTarget": "none",
      "states": ["present", "disabled"]
    },
    {
      "name": "search-field-status",
      "semanticElement": "span role=status or role=alert",
      "refTarget": "none",
      "states": ["loading", "results", "empty", "error"]
    }
  ],
  "contract": { "id": "search-field-accessibility", "version": "0.1.0" },
  "passport": { "id": "search-field-quality-passport", "version": "0.0.0" }
}
