{
  "schemaVersion": 1,
  "itemId": "combobox",
  "riskClass": 3,
  "serverBoundary": "client-island",
  "directions": ["ltr", "rtl"],
  "locales": ["en-US", "de-DE", "ar-EG", "he-IL", "ja-JP", "hi-IN"],
  "inputModalities": ["keyboard", "mouse", "touch", "screen-reader", "speech", "switch"],
  "themes": ["light", "dark", "enhanced-contrast", "forced-colors"],
  "densities": ["comfortable", "compact", "touch"],
  "stateGroups": [
    "base",
    "interaction",
    "selection",
    "form-validation",
    "async",
    "empty-error",
    "overlay-focus",
    "responsive-reflow",
    "locale-direction",
    "user-preferences",
    "long-content"
  ],
  "slots": [
    { "name": "root", "semanticElement": "div", "refTarget": "HTMLDivElement" },
    { "name": "label", "semanticElement": "label", "refTarget": "HTMLLabelElement" },
    {
      "name": "input",
      "semanticElement": "input",
      "refTarget": "HTMLInputElement",
      "states": ["open", "disabled", "readonly", "required", "invalid", "focus-visible"]
    },
    { "name": "trigger", "semanticElement": "button", "refTarget": "HTMLButtonElement" },
    { "name": "popover", "semanticElement": "div", "refTarget": "HTMLElement" },
    { "name": "listbox", "semanticElement": "div", "refTarget": "HTMLDivElement" },
    { "name": "section", "semanticElement": "section", "refTarget": "HTMLElement" },
    { "name": "item", "semanticElement": "div", "refTarget": "HTMLDivElement" },
    { "name": "description", "semanticElement": "div", "refTarget": "HTMLElement" },
    { "name": "error-message", "semanticElement": "div", "refTarget": "HTMLElement" }
  ],
  "contract": { "id": "combobox-accessibility-contract", "version": "0.1.0" },
  "passport": { "id": "combobox-quality-passport", "version": "0.1.0" }
}
