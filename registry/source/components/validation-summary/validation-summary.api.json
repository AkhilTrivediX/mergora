{
  "schemaVersion": 1,
  "itemId": "validation-summary",
  "entryExport": "ValidationSummary",
  "refTarget": "HTMLDivElement",
  "nativeProps": "React.HTMLAttributes<HTMLDivElement> with children reserved",
  "exports": [
    { "kind": "component", "name": "ValidationSummary" },
    { "kind": "function", "name": "formatValidationErrorCount" },
    { "kind": "type", "name": "ValidationFocusPolicy" },
    { "kind": "type", "name": "ValidationIssue" },
    { "kind": "type", "name": "ValidationSummaryProps" }
  ],
  "props": [
    { "name": "issues", "required": true, "type": "readonly ValidationIssue[]" },
    {
      "name": "heading",
      "required": false,
      "default": "validationSummary.heading provider key with English fallback",
      "type": "ReactNode"
    },
    { "name": "headingId", "required": false, "type": "string; generated by default" },
    { "name": "headingLevel", "required": false, "default": 2, "type": "2 | 3 | 4 | 5 | 6" },
    {
      "name": "focusPolicy",
      "required": false,
      "default": "none",
      "type": "none | summary | first-error"
    },
    {
      "name": "focusKey",
      "required": false,
      "type": "string | number; explicit validation revision"
    },
    { "name": "formatAnnouncement", "required": false, "type": "(count: number) => string" },
    { "name": "renderWhenEmpty", "required": false, "default": false, "type": "boolean" }
  ],
  "compositionPolicy": {
    "focus": "Focus moves only for a new explicit focusKey and never for ordinary issue-list updates; first-error falls back to the named summary.",
    "links": "Issue IDs are unique and non-blank. Each non-blank controlId is encoded for its fragment and resolved exactly for focus.",
    "messages": "Built-ins use validationSummary.heading and validationSummary.errorCount provider keys; explicit props win."
  }
}
