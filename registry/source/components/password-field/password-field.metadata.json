{
  "schemaVersion": 1,
  "itemId": "password-field",
  "riskClass": 2,
  "serverBoundary": "client-island",
  "directions": ["ltr", "rtl"],
  "locales": ["en-US", "de-DE", "ar-EG", "he-IL", "ja-JP", "hi-IN", "en-XA", "ar-XB"],
  "inputModalities": ["keyboard", "mouse", "touch", "screen-reader", "speech", "switch"],
  "themes": ["light", "dark", "enhanced-contrast", "forced-colors"],
  "densities": ["comfortable", "compact", "touch"],
  "stateGroups": [
    "default",
    "focus-visible",
    "empty",
    "populated",
    "revealed",
    "caps-lock",
    "rules-met",
    "rules-unmet",
    "disabled",
    "read-only",
    "invalid",
    "required",
    "autofill",
    "rtl"
  ],
  "slots": [
    {
      "name": "password-field",
      "semanticElement": "span",
      "refTarget": "none",
      "states": ["empty", "disabled", "read-only", "invalid", "revealed", "caps-lock"]
    },
    {
      "name": "password-field-input",
      "semanticElement": "input type=password or type=text while revealed",
      "refTarget": "HTMLInputElement",
      "states": ["required", "invalid", "disabled", "read-only", "autofill"]
    },
    {
      "name": "password-field-reveal",
      "semanticElement": "button",
      "refTarget": "none",
      "states": ["pressed", "disabled"]
    },
    {
      "name": "password-field-caps-lock",
      "semanticElement": "span role=status",
      "refTarget": "none",
      "states": ["empty", "caps-lock"]
    },
    {
      "name": "password-field-rules",
      "semanticElement": "ul",
      "refTarget": "none",
      "states": ["present"]
    },
    {
      "name": "password-field-rule",
      "semanticElement": "li",
      "refTarget": "none",
      "states": ["met", "not-met"]
    }
  ],
  "contract": { "id": "password-field-accessibility", "version": "0.1.0" },
  "passport": { "id": "password-field-quality-passport", "version": "0.0.0" }
}
