{
  "schemaVersion": 1,
  "itemId": "password-field",
  "entryExport": "PasswordField",
  "refTarget": "HTMLInputElement",
  "nativeProps": "React.InputHTMLAttributes<HTMLInputElement>, excluding type, value, defaultValue, and native onChange",
  "exports": [
    { "kind": "component", "name": "PasswordField" },
    { "kind": "type", "name": "PasswordFieldProps" },
    { "kind": "type", "name": "PasswordFieldRule" }
  ],
  "props": [
    { "name": "value", "required": false, "type": "string; controlled" },
    { "name": "defaultValue", "required": false, "default": "", "type": "string; uncontrolled" },
    { "name": "onChange", "required": false, "type": "(value: string) => void" },
    { "name": "rules", "required": false, "default": "[]", "type": "readonly PasswordFieldRule[]" },
    {
      "name": "showPasswordLabel",
      "required": false,
      "default": "localized Show password",
      "type": "string"
    },
    {
      "name": "hidePasswordLabel",
      "required": false,
      "default": "localized Hide password",
      "type": "string"
    },
    {
      "name": "capsLockMessage",
      "required": false,
      "default": "localized Caps Lock is on",
      "type": "string"
    },
    {
      "name": "rulesLabel",
      "required": false,
      "default": "localized Password requirements",
      "type": "string"
    },
    { "name": "ruleMetLabel", "required": false, "default": "localized Met", "type": "string" },
    {
      "name": "ruleUnmetLabel",
      "required": false,
      "default": "localized Not met",
      "type": "string"
    },
    { "name": "invalid", "required": false, "type": "boolean" },
    { "name": "rootClassName", "required": false, "type": "string" },
    { "name": "rootStyle", "required": false, "type": "React.CSSProperties" },
    { "name": "inputClassName", "required": false, "type": "string" }
  ],
  "compositionPolicy": {
    "native": "A real password input owns editing, paste, autofill, password-manager discovery, validation, form submission, and reset.",
    "reveal": "The explicit pressed reveal button changes only the presentation type and never reads, transforms, scores, logs, or transmits the credential.",
    "rules": "Consumers supply deterministic requirements; the component reports each requirement as met or not met and makes no strength estimate.",
    "field": "ID, label, description, error, required, and invalid relationships are inherited from Field unless explicitly supplied."
  }
}
