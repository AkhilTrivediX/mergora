{
  "schemaVersion": 1,
  "itemId": "native-select",
  "riskClass": 1,
  "serverBoundary": "client-island",
  "directions": ["ltr", "rtl"],
  "locales": ["en-US", "de-DE", "ar-EG", "he-IL", "ja-JP", "hi-IN", "en-XA", "ar-XB"],
  "inputModalities": ["keyboard", "mouse", "touch", "screen-reader", "speech", "switch"],
  "themes": ["light", "dark", "enhanced-contrast", "forced-colors"],
  "densities": ["comfortable", "compact", "touch"],
  "stateGroups": [
    "default",
    "focus-visible",
    "disabled",
    "invalid",
    "required",
    "single",
    "multiple",
    "mobile-picker",
    "rtl"
  ],
  "slots": [
    {
      "name": "native-select-root",
      "semanticElement": "span",
      "refTarget": "none",
      "states": ["disabled", "invalid", "multiple"]
    },
    {
      "name": "native-select",
      "semanticElement": "select",
      "refTarget": "HTMLSelectElement",
      "states": ["required", "invalid", "disabled", "multiple"]
    },
    {
      "name": "native-select-indicator",
      "semanticElement": "span aria-hidden",
      "refTarget": "none",
      "states": ["single"]
    }
  ],
  "contract": { "id": "native-select-accessibility", "version": "0.1.0" },
  "passport": { "id": "native-select-quality-passport", "version": "0.0.0" }
}
