{
  "schemaVersion": 1,
  "itemId": "color-field",
  "riskClass": 2,
  "serverBoundary": "client-island",
  "directions": ["ltr", "rtl"],
  "locales": ["en-US", "de-DE", "ar-EG", "he-IL", "ja-JP", "hi-IN", "en-XA", "ar-XB"],
  "inputModalities": ["keyboard", "mouse", "touch", "screen-reader", "speech", "switch"],
  "themes": ["light", "dark", "enhanced-contrast", "forced-colors"],
  "densities": ["comfortable", "compact", "touch"],
  "stateGroups": [
    "default",
    "focus-visible",
    "disabled",
    "read-only",
    "invalid",
    "required",
    "empty",
    "populated",
    "partial",
    "rtl"
  ],
  "slots": [
    {
      "name": "color-field",
      "semanticElement": "div",
      "refTarget": "HTMLDivElement",
      "states": [
        "disabled",
        "empty",
        "invalid",
        "pending",
        "read-only",
        "required",
        "format",
        "alpha-policy"
      ]
    },
    {
      "name": "color-field-input",
      "semanticElement": "input type=text",
      "refTarget": "HTMLInputElement through inputRef",
      "states": ["disabled", "empty", "invalid", "read-only", "required", "partial"]
    },
    {
      "name": "color-field-form-value",
      "semanticElement": "input type=hidden",
      "refTarget": "none",
      "states": ["empty", "populated", "disabled"]
    },
    {
      "name": "color-field-swatch",
      "semanticElement": "span",
      "refTarget": "none",
      "states": ["empty", "populated"]
    },
    {
      "name": "color-field-preview",
      "semanticElement": "output",
      "refTarget": "none",
      "states": ["empty", "populated"]
    },
    {
      "name": "color-field-contrast",
      "semanticElement": "output",
      "refTarget": "none",
      "states": ["unavailable", "below-threshold", "at-or-above-threshold"]
    },
    {
      "name": "color-field-error",
      "semanticElement": "p",
      "refTarget": "none",
      "states": ["invalid"]
    }
  ],
  "contract": { "id": "color-field-accessibility", "version": "0.1.0" },
  "passport": { "id": "color-field-quality-passport", "version": "0.0.0" }
}
