    },
    {
      "slot": "signature-pad-text-file",
      "element": "optional native inputs",
      "purpose": "Provides typed and file alternatives independent of canvas drawing.",
      "stability": "documented"
    },
    {
      "slot": "signature-pad-legal-caveat",
      "element": "optional paragraph",
      "purpose": "Keeps legal validity outside a misleading component guarantee.",
      "stability": "documented"
    }
  ]
