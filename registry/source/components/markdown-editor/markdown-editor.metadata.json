{
  "schemaVersion": 1,
  "itemId": "markdown-editor",
  "riskClass": 3,
  "serverBoundary": "client-island",
  "directions": ["ltr", "rtl"],
  "locales": ["en-US", "de-DE", "ar-EG", "he-IL", "ja-JP", "hi-IN", "en-XA", "ar-XB"],
  "inputModalities": ["keyboard", "mouse", "touch", "screen-reader", "speech", "switch"],
  "themes": ["light", "dark", "enhanced-contrast", "forced-colors"],
  "densities": ["comfortable", "compact", "touch"],
  "stateGroups": [
    "default",
    "enhancement-disabled",
    "enhancement-enabled",
    "controlled",
    "uncontrolled",
    "write",
    "preview",
    "split",
    "disabled",
    "read-only",
    "invalid",
    "pending",
    "error",
    "narrow",
    "rtl",
    "forced-colors",
    "reduced-motion"
  ],
  "slots": [
    {
      "name": "markdown-editor",
      "semanticElement": "div field shell",
      "refTarget": "HTMLDivElement",
      "states": ["controlled", "uncontrolled", "disabled", "read-only", "invalid", "pending"]
    },
    {
      "name": "markdown-editor-toolbar",
      "semanticElement": "optional toolbar",
      "refTarget": "none",
      "states": ["enhancement-enabled"]
    },
    {
      "name": "markdown-editor-preview",
      "semanticElement": "optional region or tabpanel",
      "refTarget": "none",
      "states": ["preview", "split"]
    },
    {
      "name": "markdown-editor-word-count",
      "semanticElement": "optional output",
      "refTarget": "none",
      "states": ["enhancement-enabled"]
    }
  ],
  "contract": { "id": "markdown-editor-accessibility", "version": "0.1.0" },
  "passport": { "id": "markdown-editor-quality-passport", "version": "0.0.0" }
}
