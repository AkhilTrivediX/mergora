{
  "schemaVersion": 1,
  "itemId": "data-grid",
  "riskClass": 3,
  "serverBoundary": "client-island",
  "directions": ["ltr", "rtl"],
  "locales": ["en-US", "de-DE", "ar-EG", "he-IL", "ja-JP", "hi-IN"],
  "inputModalities": ["keyboard", "mouse", "touch", "screen-reader", "speech", "switch"],
  "themes": ["light", "dark", "enhanced-contrast", "forced-colors"],
  "densities": ["comfortable", "compact", "touch"],
  "stateGroups": [
    "base",
    "interaction",
    "selection",
    "empty-error",
    "responsive-reflow",
    "locale-direction",
    "user-preferences",
    "long-content",
    "large-data-virtualization"
  ],
  "slots": [
    { "name": "region", "semanticElement": "div", "refTarget": "HTMLDivElement" },
    { "name": "table", "semanticElement": "table", "refTarget": "HTMLTableElement" },
    { "name": "header", "semanticElement": "thead", "refTarget": "HTMLTableSectionElement" },
    { "name": "row", "semanticElement": "tr", "refTarget": "HTMLTableRowElement" },
    { "name": "column-header", "semanticElement": "th", "refTarget": "HTMLTableCellElement" },
    { "name": "body", "semanticElement": "tbody", "refTarget": "HTMLTableSectionElement" },
    { "name": "cell", "semanticElement": "td", "refTarget": "HTMLTableCellElement" }
  ],
  "contract": { "id": "data-grid-accessibility-contract", "version": "0.1.0" },
  "passport": { "id": "data-grid-quality-passport", "version": "0.1.0" }
}
