{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mergora.vercel.app/r/v1/schemas/item-v1.schema.json",
  "title": "Mergora immutable registry item payload v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "registryId",
    "itemId",
    "kind",
    "version",
    "lastChangedVersion",
    "maturity",
    "license",
    "title",
    "description",
    "links",
    "compatibility",
    "files",
    "registryDependencies",
    "dependencies",
    "structuredPatches",
    "migrations",
    "contract",
    "passport",
    "examples",
    "importPaths",
    "payloadDigest"
  ],
  "properties": {
    "schemaVersion": { "$ref": "common-v1.schema.json#/$defs/schemaVersion" },
    "registryId": { "$ref": "common-v1.schema.json#/$defs/catalogId" },
    "itemId": { "$ref": "common-v1.schema.json#/$defs/catalogId" },
    "kind": { "enum": ["component", "hook", "utility", "system", "kit", "theme", "contract"] },
    "version": { "$ref": "common-v1.schema.json#/$defs/semver" },
    "lastChangedVersion": { "$ref": "common-v1.schema.json#/$defs/semver" },
    "maturity": { "$ref": "common-v1.schema.json#/$defs/maturity" },
    "license": { "$ref": "common-v1.schema.json#/$defs/spdxLicense" },
    "title": { "$ref": "common-v1.schema.json#/$defs/nonEmptyString" },
    "description": { "$ref": "common-v1.schema.json#/$defs/nonEmptyString" },
    "links": {
      "type": "object",
      "additionalProperties": false,
      "required": ["docs", "source", "changelog", "passport", "contract"],
      "properties": {
        "docs": { "$ref": "common-v1.schema.json#/$defs/httpsUrl" },
        "source": { "$ref": "common-v1.schema.json#/$defs/httpsUrl" },
        "changelog": { "$ref": "common-v1.schema.json#/$defs/httpsUrl" },
        "passport": { "$ref": "common-v1.schema.json#/$defs/immutableUrl" },
        "contract": { "$ref": "common-v1.schema.json#/$defs/immutableUrl" }
      }
    },
    "compatibility": { "$ref": "common-v1.schema.json#/$defs/compatibility" },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "logicalPath",
          "targetRole",
          "mediaType",
          "bytes",
          "digest",
          "executable",
          "transformPipeline"
        ],
        "properties": {
          "logicalPath": { "$ref": "common-v1.schema.json#/$defs/logicalPath" },
          "targetRole": {
            "enum": [
              "component",
              "hook",
              "lib",
              "system",
              "kit",
              "style",
              "token",
              "contract",
              "example"
            ]
          },
          "mediaType": {
            "enum": [
              "text/typescript",
              "text/typescript-jsx",
              "text/javascript",
              "text/javascript-jsx",
              "text/css",
              "application/json",
              "application/dtcg+json",
              "text/markdown",
              "application/octet-stream",
              "font/woff2",
              "image/svg+xml"
            ]
          },
          "bytes": { "$ref": "common-v1.schema.json#/$defs/byteCount" },
          "content": { "type": "string", "maxLength": 4194304 },
          "sourceUrl": { "$ref": "common-v1.schema.json#/$defs/immutableUrl" },
          "digest": { "$ref": "common-v1.schema.json#/$defs/sha256" },
          "executable": { "const": false },
          "transformPipeline": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["adapter", "version"],
              "properties": {
                "adapter": {
                  "enum": [
                    "alias-rewrite",
                    "import-rewrite",
                    "target-map",
                    "format",
                    "token-resolve",
                    "none"
                  ]
                },
                "version": { "$ref": "common-v1.schema.json#/$defs/semver" }
              }
            },
            "maxItems": 16
          }
        },
        "oneOf": [
          { "required": ["content"], "not": { "required": ["sourceUrl"] } },
          { "required": ["sourceUrl"], "not": { "required": ["content"] } }
        ]
      },
      "maxItems": 1024
    },
    "registryDependencies": {
      "type": "array",
      "items": { "$ref": "common-v1.schema.json#/$defs/qualifiedItemId" },
      "uniqueItems": true,
      "maxItems": 256
    },
    "dependencies": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtime", "development"],
      "properties": {
        "runtime": { "$ref": "common-v1.schema.json#/$defs/dependencyMap" },
        "development": { "$ref": "common-v1.schema.json#/$defs/dependencyMap" }
      }
    },
    "structuredPatches": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "adapter", "semanticKey", "desiredValue", "reversible"],
        "properties": {
          "id": { "$ref": "common-v1.schema.json#/$defs/catalogId" },
          "adapter": {
            "enum": [
              "css-import",
              "css-source",
              "css-token-block",
              "package-dependency",
              "tsconfig-path",
              "tsconfig-include",
              "framework-config"
            ]
          },
          "semanticKey": { "type": "string", "minLength": 1, "maxLength": 512 },
          "desiredValue": {
            "oneOf": [
              { "type": "string", "maxLength": 4096 },
              { "type": "number" },
              { "type": "boolean" },
              { "type": "array", "items": { "type": "string", "maxLength": 1024 }, "maxItems": 128 }
            ]
          },
          "reversible": { "const": true }
        }
      },
      "maxItems": 256
    },
    "migrations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "from", "to", "phase", "adapter", "arguments"],
        "properties": {
          "id": { "$ref": "common-v1.schema.json#/$defs/catalogId" },
          "from": { "$ref": "common-v1.schema.json#/$defs/semverRange" },
          "to": { "$ref": "common-v1.schema.json#/$defs/semverRange" },
          "phase": { "enum": ["remote", "proposed"] },
          "adapter": {
            "enum": [
              "rename-file",
              "rename-export",
              "rename-prop",
              "rename-token",
              "config-v1",
              "manual-checklist"
            ]
          },
          "arguments": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "from": { "type": "string", "minLength": 1, "maxLength": 1024 },
              "to": { "type": "string", "minLength": 1, "maxLength": 1024 },
              "checklist": {
                "type": "array",
                "items": { "type": "string", "minLength": 1, "maxLength": 1024 },
                "maxItems": 64
              }
            }
          }
        }
      },
      "maxItems": 128
    },
    "contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": { "$ref": "common-v1.schema.json#/$defs/catalogId" },
        "version": { "$ref": "common-v1.schema.json#/$defs/semver" }
      }
    },
    "passport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": { "$ref": "common-v1.schema.json#/$defs/catalogId" },
        "version": { "$ref": "common-v1.schema.json#/$defs/semver" }
      }
    },
    "examples": {
      "type": "array",
      "items": { "$ref": "common-v1.schema.json#/$defs/logicalPath" },
      "uniqueItems": true,
      "maxItems": 128
    },
    "importPaths": {
      "type": "array",
      "items": { "type": "string", "pattern": "^mergora-ui(?:/[a-z0-9-]+)?$" },
      "uniqueItems": true,
      "maxItems": 64
    },
    "payloadDigest": { "$ref": "common-v1.schema.json#/$defs/sha256" }
  }
}
