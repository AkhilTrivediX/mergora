{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://akhiltrivedix.github.io/mergora/r/v1/schemas/result-envelope-v1.schema.json",
  "title": "Mergora CLI JSON result envelope v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "command",
    "ok",
    "status",
    "exitCode",
    "result",
    "warnings",
    "errors"
  ],
  "properties": {
    "schemaVersion": { "$ref": "common-v1.schema.json#/$defs/schemaVersion" },
    "command": { "type": "string", "pattern": "^[a-z]+(?:-[a-z]+)*$", "maxLength": 80 },
    "ok": { "type": "boolean" },
    "status": {
      "enum": [
        "success",
        "created",
        "planned",
        "applied",
        "no-op",
        "differences",
        "no-differences",
        "fix-planned",
        "healthy",
        "issues-found",
        "pass",
        "fail",
        "incomplete",
        "not-applicable",
        "conflict",
        "conflicted",
        "resolved",
        "committed",
        "rolled-back",
        "recorded",
        "manual-only",
        "transaction",
        "report",
        "cleaned",
        "match",
        "mismatch",
        "not-pinned",
        "not-checked",
        "verified",
        "identity-mismatch",
        "valid",
        "rollback-planned",
        "resume-planned",
        "finalize-planned",
        "invalid",
        "unavailable",
        "incompatible",
        "recovery-required",
        "failed",
        "consent-required",
        "error"
      ]
    },
    "exitCode": { "type": "integer", "minimum": 0, "maximum": 12 },
    "result": {
      "type": ["object", "array", "string", "number", "boolean", "null"]
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 4096
      },
      "maxItems": 256
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "message"],
        "properties": {
          "code": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]+$", "maxLength": 120 },
          "message": { "$ref": "common-v1.schema.json#/$defs/nonEmptyString" },
          "recovery": { "type": "string", "minLength": 1, "maxLength": 4096 },
          "target": { "$ref": "common-v1.schema.json#/$defs/projectRelativePath" },
          "docs": { "$ref": "common-v1.schema.json#/$defs/httpsUrl" },
          "transactionId": {
            "type": "string",
            "pattern": "^[0-9]{8}T[0-9]{6}(?:\\.[0-9]{3})?Z-[0-9a-f]{32}$"
          },
          "reportId": { "type": "string", "pattern": "^report-[0-9a-f]{16}$" }
        }
      },
      "maxItems": 256
    }
  },
  "allOf": [
    {
      "if": { "properties": { "ok": { "const": true } }, "required": ["ok"] },
      "then": {
        "properties": {
          "exitCode": { "const": 0 },
          "errors": { "maxItems": 0 }
        }
      },
      "else": { "properties": { "exitCode": { "minimum": 1 } } }
    },
    {
      "if": { "properties": { "status": { "const": "error" } }, "required": ["status"] },
      "then": {
        "properties": {
          "ok": { "const": false },
          "errors": { "minItems": 1 }
        }
      }
    }
  ]
}
