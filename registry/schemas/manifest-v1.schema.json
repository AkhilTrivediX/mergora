{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://akhiltrivedix.github.io/mergora/r/v1/schemas/manifest-v1.schema.json",
  "title": "Mergora portable provenance manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "projectId",
    "toolchain",
    "items",
    "sharedTargets",
    "dependencyOwners"
  ],
  "properties": {
    "$schema": {
      "const": "https://akhiltrivedix.github.io/mergora/r/v1/schemas/manifest-v1.schema.json"
    },
    "schemaVersion": { "$ref": "common-v1.schema.json#/$defs/schemaVersion" },
    "projectId": { "$ref": "common-v1.schema.json#/$defs/sha256" },
    "toolchain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cli", "schema", "transformer", "formatter"],
      "properties": {
        "cli": { "$ref": "common-v1.schema.json#/$defs/semver" },
        "schema": { "$ref": "common-v1.schema.json#/$defs/semver" },
        "transformer": { "$ref": "common-v1.schema.json#/$defs/semver" },
        "formatter": {
          "type": "string",
          "pattern": "^(?:none|mergora@[0-9]+|[a-z0-9@/_-]+@[0-9A-Za-z.+-]+)$",
          "maxLength": 160
        }
      }
    },
    "items": {
      "type": "object",
      "propertyNames": { "$ref": "common-v1.schema.json#/$defs/qualifiedItemId" },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "registry",
          "itemId",
          "kind",
          "requested",
          "resolved",
          "payload",
          "mode",
          "direct",
          "transformContextDigest",
          "transformContext",
          "files",
          "registryDependencies",
          "dependencies",
          "structuredPatches",
          "contractVersion",
          "lastMigration"
        ],
        "properties": {
          "registry": { "$ref": "common-v1.schema.json#/$defs/catalogId" },
          "itemId": { "$ref": "common-v1.schema.json#/$defs/catalogId" },
          "kind": {
            "enum": ["component", "hook", "utility", "system", "kit", "theme", "contract"]
          },
          "requested": { "$ref": "common-v1.schema.json#/$defs/semverRange" },
          "resolved": { "$ref": "common-v1.schema.json#/$defs/semver" },
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["url", "digest"],
            "properties": {
              "url": { "$ref": "common-v1.schema.json#/$defs/immutableUrl" },
              "digest": { "$ref": "common-v1.schema.json#/$defs/sha256" }
            }
          },
          "mode": { "enum": ["source", "package"] },
          "direct": { "type": "boolean" },
          "transformContextDigest": { "$ref": "common-v1.schema.json#/$defs/sha256" },
          "transformContext": {
            "type": "object",
            "additionalProperties": false,
            "required": ["targets", "aliases", "styling"],
            "properties": {
              "targets": {
                "type": "object",
                "propertyNames": {
                  "enum": ["components", "hooks", "lib", "systems", "kits", "styles", "tokens"]
                },
                "additionalProperties": {
                  "$ref": "common-v1.schema.json#/$defs/projectRelativePath"
                }
              },
              "aliases": {
                "type": "object",
                "propertyNames": {
                  "enum": ["components", "hooks", "lib", "systems", "kits", "styles", "tokens"]
                },
                "additionalProperties": { "type": "string", "minLength": 1, "maxLength": 256 }
              },
              "styling": {
                "type": "object",
                "additionalProperties": false,
                "required": ["engine", "tokenPreset", "density", "direction"],
                "properties": {
                  "engine": { "const": "tailwind-v4" },
                  "tokenPreset": { "$ref": "common-v1.schema.json#/$defs/catalogId" },
                  "density": { "enum": ["comfortable", "compact", "touch"] },
                  "direction": { "enum": ["ltr", "rtl", "auto"] }
                }
              }
            }
          },
          "files": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "logicalPath",
                "target",
                "role",
                "base",
                "installed",
                "mediaType",
                "executable"
              ],
              "properties": {
                "logicalPath": { "$ref": "common-v1.schema.json#/$defs/logicalPath" },
                "target": { "$ref": "common-v1.schema.json#/$defs/projectRelativePath" },
                "role": {
                  "enum": [
                    "component",
                    "hook",
                    "lib",
                    "system",
                    "kit",
                    "style",
                    "token",
                    "contract",
                    "example"
                  ]
                },
                "base": { "$ref": "common-v1.schema.json#/$defs/sha256" },
                "installed": {
                  "oneOf": [{ "$ref": "common-v1.schema.json#/$defs/sha256" }, { "type": "null" }]
                },
                "mediaType": { "type": "string", "minLength": 1, "maxLength": 120 },
                "executable": { "const": false },
                "tombstone": { "type": "boolean" }
              }
            },
            "maxItems": 2048
          },
          "importSubpaths": {
            "type": "array",
            "items": { "type": "string", "pattern": "^mergora-ui(?:/[a-z0-9-]+)?$" },
            "uniqueItems": true,
            "maxItems": 128
          },
          "registryDependencies": {
            "type": "array",
            "items": { "$ref": "common-v1.schema.json#/$defs/qualifiedItemId" },
            "uniqueItems": true,
            "maxItems": 256
          },
          "dependencies": {
            "type": "object",
            "additionalProperties": false,
            "required": ["runtime", "development"],
            "properties": {
              "runtime": { "$ref": "common-v1.schema.json#/$defs/dependencyMap" },
              "development": { "$ref": "common-v1.schema.json#/$defs/dependencyMap" }
            }
          },
          "structuredPatches": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "adapter", "semanticKey", "ownedValueDigest"],
              "properties": {
                "id": { "$ref": "common-v1.schema.json#/$defs/catalogId" },
                "adapter": {
                  "enum": [
                    "css-import",
                    "css-source",
                    "css-token-block",
                    "package-dependency",
                    "tsconfig-path",
                    "tsconfig-include",
                    "framework-config"
                  ]
                },
                "semanticKey": { "type": "string", "minLength": 1, "maxLength": 512 },
                "ownedValueDigest": { "$ref": "common-v1.schema.json#/$defs/sha256" }
              }
            },
            "maxItems": 256
          },
          "contractVersion": { "$ref": "common-v1.schema.json#/$defs/semver" },
          "lastMigration": {
            "oneOf": [{ "$ref": "common-v1.schema.json#/$defs/catalogId" }, { "type": "null" }]
          }
        }
      },
      "maxProperties": 4096
    },
    "sharedTargets": {
      "type": "object",
      "propertyNames": { "$ref": "common-v1.schema.json#/$defs/projectRelativePath" },
      "additionalProperties": {
        "type": "array",
        "items": { "$ref": "common-v1.schema.json#/$defs/catalogId" },
        "uniqueItems": true
      }
    },
    "dependencyOwners": {
      "type": "object",
      "propertyNames": { "pattern": "^(?:runtime|development):(?:@[a-z0-9._-]+/)?[a-z0-9._-]+$" },
      "additionalProperties": {
        "type": "array",
        "items": { "$ref": "common-v1.schema.json#/$defs/qualifiedItemId" },
        "uniqueItems": true
      }
    }
  }
}
