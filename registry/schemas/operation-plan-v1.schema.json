{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://akhiltrivedix.github.io/mergora/r/v1/schemas/plan-v1.schema.json",
  "title": "Mergora material operation plan v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "command",
    "cliVersion",
    "projectRoot",
    "configDigest",
    "manifestPreconditionDigest",
    "planDigest",
    "registries",
    "items",
    "fileOperations",
    "dependencyChanges",
    "structuredPatches",
    "migrations",
    "contractChanges",
    "warnings",
    "consentRequirements",
    "conflicts",
    "estimatedBytes",
    "validationSuite",
    "rollbackAvailable"
  ],
  "properties": {
    "schemaVersion": { "$ref": "common-v1.schema.json#/$defs/schemaVersion" },
    "command": {
      "enum": [
        "create",
        "clean",
        "init",
        "add",
        "remove",
        "update",
        "resolve",
        "rollback",
        "recover",
        "doctor-fix",
        "theme-apply",
        "migrate",
        "adopt",
        "vendor",
        "registry-enroll",
        "registry-remove"
      ]
    },
    "cliVersion": { "$ref": "common-v1.schema.json#/$defs/semver" },
    "projectRoot": { "const": "." },
    "configDigest": { "$ref": "common-v1.schema.json#/$defs/sha256" },
    "manifestPreconditionDigest": {
      "oneOf": [{ "$ref": "common-v1.schema.json#/$defs/sha256" }, { "type": "null" }]
    },
    "planDigest": { "$ref": "common-v1.schema.json#/$defs/sha256" },
    "registries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "identityDigest",
          "release",
          "manifestDigest",
          "source",
          "trust",
          "evidenceTier"
        ],
        "properties": {
          "id": { "$ref": "common-v1.schema.json#/$defs/catalogId" },
          "identityDigest": { "$ref": "common-v1.schema.json#/$defs/sha256" },
          "release": { "$ref": "common-v1.schema.json#/$defs/semver" },
          "manifestDigest": { "$ref": "common-v1.schema.json#/$defs/sha256" },
          "source": { "enum": ["network", "verified-cache", "vendor", "mirror"] },
          "trust": { "$ref": "common-v1.schema.json#/$defs/registryTrust" },
          "evidenceTier": { "enum": ["complete", "partial", "not-supplied"] }
        }
      },
      "maxItems": 32
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "direct", "requested", "fromVersion", "toVersion", "mode"],
        "properties": {
          "id": { "$ref": "common-v1.schema.json#/$defs/qualifiedItemId" },
          "direct": { "type": "boolean" },
          "requested": { "$ref": "common-v1.schema.json#/$defs/semverRange" },
          "fromVersion": {
            "oneOf": [{ "$ref": "common-v1.schema.json#/$defs/semver" }, { "type": "null" }]
          },
          "toVersion": {
            "oneOf": [{ "$ref": "common-v1.schema.json#/$defs/semver" }, { "type": "null" }]
          },
          "mode": { "enum": ["source", "package"] }
        }
      },
      "maxItems": 4096
    },
    "fileOperations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "operation",
          "target",
          "owner",
          "base",
          "local",
          "remote",
          "proposed",
          "mediaType",
          "risk",
          "reason"
        ],
        "properties": {
          "operation": {
            "enum": [
              "add",
              "fast-forward",
              "semantic-merge",
              "keep-local",
              "delete",
              "local-delete",
              "structured-patch",
              "binary-replace",
              "conflict",
              "no-op"
            ]
          },
          "target": { "$ref": "common-v1.schema.json#/$defs/projectRelativePath" },
          "owner": { "$ref": "common-v1.schema.json#/$defs/qualifiedItemId" },
          "base": {
            "oneOf": [{ "$ref": "common-v1.schema.json#/$defs/sha256" }, { "type": "null" }]
          },
          "local": {
            "oneOf": [{ "$ref": "common-v1.schema.json#/$defs/sha256" }, { "type": "null" }]
          },
          "remote": {
            "oneOf": [{ "$ref": "common-v1.schema.json#/$defs/sha256" }, { "type": "null" }]
          },
          "proposed": {
            "oneOf": [{ "$ref": "common-v1.schema.json#/$defs/sha256" }, { "type": "null" }]
          },
          "mediaType": { "type": "string", "minLength": 1, "maxLength": 120 },
          "risk": {
            "enum": ["ordinary", "review-required", "destructive", "conflict", "security-blocked"]
          },
          "reason": { "$ref": "common-v1.schema.json#/$defs/nonEmptyString" }
        }
      },
      "maxItems": 8192
    },
    "dependencyChanges": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["scope", "package", "operation", "from", "to", "owners"],
        "properties": {
          "scope": { "enum": ["runtime", "development"] },
          "package": { "$ref": "common-v1.schema.json#/$defs/packageName" },
          "operation": { "enum": ["add", "remove", "change"] },
          "from": {
            "oneOf": [{ "$ref": "common-v1.schema.json#/$defs/semverRange" }, { "type": "null" }]
          },
          "to": {
            "oneOf": [{ "$ref": "common-v1.schema.json#/$defs/semverRange" }, { "type": "null" }]
          },
          "owners": {
            "type": "array",
            "items": { "$ref": "common-v1.schema.json#/$defs/qualifiedItemId" },
            "uniqueItems": true,
            "minItems": 1
          }
        }
      },
      "maxItems": 1024
    },
    "structuredPatches": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "adapter", "semanticKey", "target", "owner", "operation"],
        "properties": {
          "id": { "$ref": "common-v1.schema.json#/$defs/catalogId" },
          "adapter": {
            "enum": [
              "css-import",
              "css-source",
              "css-token-block",
              "package-dependency",
              "tsconfig-path",
              "tsconfig-include",
              "framework-config"
            ]
          },
          "semanticKey": { "type": "string", "minLength": 1, "maxLength": 512 },
          "target": { "$ref": "common-v1.schema.json#/$defs/projectRelativePath" },
          "owner": { "$ref": "common-v1.schema.json#/$defs/qualifiedItemId" },
          "operation": { "enum": ["add", "change", "remove", "no-op", "conflict"] }
        }
      },
      "maxItems": 1024
    },
    "migrations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "adapter", "phase"],
        "properties": {
          "id": { "$ref": "common-v1.schema.json#/$defs/catalogId" },
          "adapter": {
            "enum": [
              "rename-file",
              "rename-export",
              "rename-prop",
              "rename-token",
              "config-v1",
              "mode-source-package-v1",
              "manual-checklist"
            ]
          },
          "phase": { "enum": ["remote", "proposed"] }
        }
      },
      "maxItems": 128
    },
    "contractChanges": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["item", "from", "to"],
        "properties": {
          "item": { "$ref": "common-v1.schema.json#/$defs/qualifiedItemId" },
          "from": {
            "oneOf": [{ "$ref": "common-v1.schema.json#/$defs/semver" }, { "type": "null" }]
          },
          "to": { "$ref": "common-v1.schema.json#/$defs/semver" }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": { "$ref": "common-v1.schema.json#/$defs/nonEmptyString" },
      "maxItems": 256
    },
    "consentRequirements": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "flag", "reason"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9:._-]{0,255}$",
            "minLength": 1,
            "maxLength": 256
          },
          "flag": {
            "type": "string",
            "pattern": "^--[a-z0-9]+(?:-[a-z0-9]+)*(?:(?:=| )[A-Za-z0-9][A-Za-z0-9:._/-]*)?$",
            "maxLength": 1024
          },
          "reason": { "$ref": "common-v1.schema.json#/$defs/nonEmptyString" }
        }
      }
    },
    "conflicts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["target", "kind", "reason"],
        "properties": {
          "target": { "$ref": "common-v1.schema.json#/$defs/projectRelativePath" },
          "kind": {
            "enum": [
              "add-add",
              "modify-modify",
              "modify-delete",
              "delete-modify",
              "binary",
              "ownership",
              "structured-patch",
              "parse",
              "keep-region"
            ]
          },
          "reason": { "$ref": "common-v1.schema.json#/$defs/nonEmptyString" }
        }
      }
    },
    "estimatedBytes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["download", "write"],
      "properties": {
        "download": { "$ref": "common-v1.schema.json#/$defs/byteCount" },
        "write": { "$ref": "common-v1.schema.json#/$defs/byteCount" }
      }
    },
    "validationSuite": {
      "type": "array",
      "items": {
        "enum": [
          "schema",
          "digest",
          "path",
          "collision",
          "parse",
          "type-imports",
          "ownership",
          "dependency",
          "tokens",
          "accessibility-contract",
          "project-configured"
        ]
      },
      "uniqueItems": true
    },
    "rollbackAvailable": { "type": "boolean" }
  }
}
