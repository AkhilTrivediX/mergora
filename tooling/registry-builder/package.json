{
  "name": "@mergora-internal/registry-builder",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "generate": "node src/cli.ts --write",
    "generated:check": "node src/cli.ts --check",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "typescript": "catalog:"
  }
}
