{
  "name": "@mergora-internal/contract-runner",
  "version": "0.0.0",
  "private": true,
  "description": "Deterministic contract execution without implicit skips or fabricated passes",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "mergora-contracts": "workspace:*"
  },
  "devDependencies": {
    "typescript": "catalog:"
  }
}
