{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["playwright.config.ts", "vitest.config.ts", "tests/**/*.ts", "tests/**/*.tsx"],
  "exclude": ["tests/packed-consumers/fixtures/**"]
}
